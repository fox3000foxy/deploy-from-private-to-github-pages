{
  "name": "deploy-from-private-to-github-pages",
  "version": "1.0.0",
  "description": "GitHub Action that deploys a build directory to a GitHub Pages repo/branch.",
  "main": "dist/index.js",
  "scripts": {
    "build:ts": "tsc --project tsconfig.json",
    "compile": "pnpm build && ncc build build/index.js -o dist",
    "build": "tsc -p tsconfig.json",
    "clean": "npx rimraf -rf dist build"
  },
  "dependencies": {
    "@actions/artifact": "2",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.35",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3"
  }
}
